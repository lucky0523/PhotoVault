<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        允许明文 HTTP 流量。PhotoVault 的 NAS 服务端通常部署在局域网内，
        使用 HTTP 直连（无 HTTPS 证书），因此需要允许明文通信。
        生产环境若通过 Caddy 配置了 HTTPS，客户端使用 https:// 地址即可走加密通道。
    -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
